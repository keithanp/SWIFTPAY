# Google AI Studio / Gemini API key (https://aistudio.google.com/apikey)
# Injected at build time as process.env.API_KEY via vite.config.ts
VITE_API_KEY=

# Optional: absolute API URL for the browser (e.g. https://api.example.com). Leave unset to use
# same-origin /v1 (Vite dev server proxies to VITE_API_PROXY_TARGET / 127.0.0.1:4000).
# VITE_API_BASE_URL=
# VITE_API_PROXY_TARGET=http://127.0.0.1:4000

# ------------------------------
# Backend/API secrets (server-side only)
# ------------------------------
# Rotate these before production.
# JWT_SECRET=replace-with-strong-random-secret
# ENCRYPTION_KEY=replace-with-32-byte-minimum-random-key
# PAYOUT_WEBHOOK_SECRET=replace-with-random-secret

# Provider config
# PAYOUT_PROVIDER=internal_stub # use stripe for live adapter
# STRIPE_SECRET_KEY=sk_live_...
# STRIPE_WEBHOOK_SECRET=whsec_...
# APP_BASE_URL=http://localhost:5173
# PAYOUT_RETRY_MAX=3
# PAYOUT_RETRY_BASE_MS=250
# SETTLEMENT_SWEEP_MS=30000
